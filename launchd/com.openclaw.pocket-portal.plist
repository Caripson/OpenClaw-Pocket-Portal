<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.openclaw.pocket-portal</string>

  <!-- Edit these paths to match your installation -->
  <key>WorkingDirectory</key>
  <string>/ABSOLUTE/PATH/TO/OpenClaw-Pocket-Portal</string>

  <key>EnvironmentVariables</key>
  <dict>
    <!-- Bind to a specific LAN IP (recommended) or 0.0.0.0 -->
    <key>HOST</key>
    <string>0.0.0.0</string>
    <key>PORT</key>
    <string>4377</string>
    <key>NODE_ENV</key>
    <string>production</string>
  </dict>

  <key>ProgramArguments</key>
  <array>
    <!-- Prefer an absolute path to node -->
    <string>/usr/local/bin/node</string>
    <string>/ABSOLUTE/PATH/TO/OpenClaw-Pocket-Portal/src/server.js</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/tmp/pocket-portal.out.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/pocket-portal.err.log</string>
</dict>
</plist>
